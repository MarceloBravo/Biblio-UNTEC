<div class="modal" tabindex="-1" role="dialog">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modal-title">Modal title</h5>
      </div>
      <div class="modal-body">
        <p id="modal-message">Modal body text goes here.</p>
      </div>
      <div class="modal-footer">
        <button type="button" id="btn-modal-aceptar" class="btn btn-primary">Save changes</button>
        <button type="button" id="btn-modal-cancelar" class="btn btn-secondary" data-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>